# ── LLM provider ─────────────────────────────────────────────────────────
# Which backend drives the agent: "groq" (default) or "gemini".
LLM_PROVIDER=groq

# ── Groq credentials & model ───────────────────────────────────────────────
# Get free keys at https://console.groq.com/keys . Keep them secret.
# GROQ_API_KEY_2 (and _3) are OPTIONAL fallbacks: when the active key hits a
# rate limit, the agent automatically rotates to the next one.
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Groq model id. llama-3.3-70b-versatile is a strong, JSON-reliable default.
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini (Google AI) credentials & model — used only if LLM_PROVIDER=gemini ─
# Your Google AI Studio API key. Keep this secret; never commit the real .env.
GEMINI_API_KEY=your_api_key_here

# Model id. Override here if your access uses a different model string.
GEMINI_MODEL=gemini-3.1-flash-lite

# OPTIONAL: custom gateway / proxy base URL. Leave blank to hit Google directly.
GEMINI_BASE_URL=

# ── Browser ──────────────────────────────────────────────────────────────
# true  -> run Chromium without a visible window (good for the Web-UI/servers)
# false -> show the browser window (good for a live CLI demo)
HEADLESS=false

# Viewport size used for screenshots and coordinate math.
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# ── Agent ──────────────────────────────────────────────────────────────-
# Hard cap on reasoning/action steps before the agent gives up.
MAX_STEPS=25

# Per-action / navigation timeout in milliseconds.
ACTION_TIMEOUT_MS=15000
